<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LlamadaActivity"
    android:orientation="vertical"
    android:gravity="center">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/avandonastevideollamada"
        android:textSize="36sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />
    <ImageView
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:src="@drawable/baseline_call_end_24"/>
    <Button
        android:id="@+id/btnvolverainicio"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="@string/volver_a_inicio"
        android:background="@drawable/boton_redondeado"
        android:backgroundTint="@color/fb_color"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>
</LinearLayout>