<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/root_view"
    tools:context=".ChatActivity">

    <include android:id="@+id/chat_toolbar"
        layout="@layout/toolbar_principal"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listamensajesresikler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/chat_toolbar"
        android:layout_above="@+id/chat_linear_layout"/>
    <LinearLayout
        android:id="@+id/chat_linear_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:background="@drawable/textos">

        <ImageView
            android:id="@+id/enviar_archivos_boton"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:src="@drawable/file"/>
        <ImageView
            android:id="@+id/emojiboton"
            android:layout_width="30sp"
            android:layout_height="40sp"
            android:src="@drawable/happy"/>

        <com.vanniktech.emoji.EmojiEditText
            android:id="@+id/mensaje"
            android:layout_width="218dp"
            android:layout_height="wrap_content"
            android:hint="@string/escribir_mensaje"
            android:padding="10dp"
            android:maxLines="5"/>
        <ImageView
            android:id="@+id/enviar_mensaje_boton"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:src="@drawable/send"/>

    </LinearLayout>

</RelativeLayout>