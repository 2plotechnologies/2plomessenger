<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/root_view_group"
    tools:context=".GrupoChatActivity">

    <include
        android:id="@+id/grupochat_bar_layout"
        layout="@layout/toolbar_principal">
    </include>

    <ScrollView
        android:id="@+id/mi_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/milinearlayout"
        android:layout_below="@+id/grupochat_bar_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.vanniktech.emoji.EmojiTextView
                android:id="@+id/grupo_chat_texto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="50dp"
                android:padding="10dp"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="20dp" />


        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/milinearlayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="1dp">
        <ImageView
            android:id="@+id/enviar_archivos_boton_grupos"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:src="@drawable/file"/>
        <ImageView
            android:id="@+id/emojiboton_grupos"
            android:layout_width="30sp"
            android:layout_height="40sp"
            android:src="@drawable/happy"/>
        <com.vanniktech.emoji.EmojiEditText
            android:id="@+id/texto_grupo_chat"
            android:layout_width="218dp"
            android:layout_height="wrap_content"
            android:hint="Escribir mensaje"
            android:padding="15dp"/>

        <ImageView
            android:id="@+id/enviar_mensaje_grupo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/send"/>

    </LinearLayout>

</RelativeLayout>