<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BuscarAmigosActivity">

    <include android:id="@+id/buscar_amigos_toolbar"
        layout="@layout/toolbar_principal"></include>
    <SearchView
        android:id="@+id/buscador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/buscar_amigos_toolbar"
        android:queryHint="@string/buscador">
    </SearchView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/buscar_amigos_recyclerview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/buscador"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"/>

</RelativeLayout>