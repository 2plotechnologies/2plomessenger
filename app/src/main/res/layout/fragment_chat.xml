<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_gravity="center"
    tools:context=".ChatFragment">
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_lista"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"  />

    <ImageButton
        android:id="@+id/btn_open_ai"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="end"
        android:layout_margin="20dp"
        android:background="@drawable/boton_redondo"
        android:backgroundTint="@color/fb_color"
        android:contentDescription="Chat AI"
        android:scaleType="fitXY"
        android:src="@drawable/twoploai" />

    <ImageButton
        android:id="@+id/btnbuscarcontactos"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="20dp"
        android:layout_gravity="end"
        android:background="@drawable/boton_redondo"
        android:backgroundTint="@color/fb_color"
        android:padding="10dp"
        android:scaleType="fitXY"
        android:src="@drawable/baseline_chat_24" />
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_hay_chats_presione_el_bot_n_para_ver_los_usuarios_de_la_app"
        android:visibility="gone"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@android:color/black" />
</LinearLayout>