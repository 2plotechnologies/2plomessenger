<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ChatFragment">

    <!-- Lista de chats -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_lista"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"/> <!-- deja espacio para los botones flotantes -->

    <!-- Texto cuando no hay chats -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_hay_chats_presione_el_bot_n_para_ver_los_usuarios_de_la_app"
        android:visibility="gone"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@android:color/black"
        android:layout_gravity="center"/>

    <!-- Botón AI -->

    <!-- Botón Buscar contactos -->

    <ImageButton
        android:id="@+id/btn_open_ai"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/boton_redondo"
        android:backgroundTint="@color/fb_color"
        android:contentDescription="Chat IA"
        android:scaleType="fitXY"
        android:src="@drawable/twoploai" />

    <ImageButton
        android:id="@+id/btnbuscarcontactos"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/boton_redondo"
        android:backgroundTint="@color/fb_color"
        android:padding="10dp"
        android:scaleType="fitXY"
        android:src="@drawable/baseline_chat_24" />

</FrameLayout>