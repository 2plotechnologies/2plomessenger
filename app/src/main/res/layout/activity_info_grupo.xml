<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InfoGrupoActivity">
    <include
        android:id="@+id/toolbar_infogrupo"
        layout="@layout/toolbar_principal"></include>

    <LinearLayout
        android:id="@+id/ngl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/toolbar_infogrupo"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/ng"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del grupo:"></TextView>

        <EditText
            android:id="@+id/nombregrupo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"></EditText>
    </LinearLayout>
    <TextView
        android:id="@+id/txcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/ngl"
        android:text="Codigo del grupo:"
        android:gravity="center"
        android:textSize="20sp">
    </TextView>
    <TextView
        android:id="@+id/codigogrupo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txcode"
        android:gravity="center"
        android:textSize="30sp"
        android:textStyle="bold">
    </TextView>
    <Button
        android:id="@+id/btnsalir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/codigogrupo"
        android:background="@color/red"
        android:text="Salir del grupo" />
<TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_below="@+id/btnsalir"
    android:text="Tenga en cuenta que el chat grupal aun esta en desarrollo, tenga paciencia y espere a las nuevas actualizaciones para obtener mejoras"/>

</RelativeLayout>